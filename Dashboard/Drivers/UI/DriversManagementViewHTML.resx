  <data name="htmlContentControl2.HtmlTemplate.Styles" xml:space="preserve">
    <value>.kpi-row { 
    display: flex; 
    flex-direction: row; 
    justify-content: center;   /* Yatayda ortalar */
    align-items: flex-start;   /* Dikeyde en üste (top) yaslar */
    width: 100%; 
    font-family: 'Segoe UI', sans-serif;    
}
.kpi-card { 
    background-color: #FFFFFF; 
    border: 1px solid #D1D5DB; 
    border-radius: 4px; 
    padding: 12px 16px;        /* 80px'e sığması için padding küçültüldü */
    margin-right: 24px; 
    height: 80px;              /* İSTEDİĞİN SABİT YÜKSEKLİK */
    width: 100%;
    flex-grow: 1;              /* Kartları eşit esnetir */
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
}
.no-margin { 
    margin-right: 0; 
}
.kpi-top { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
}
.kpi-title { 
    font-size: 14px; 
    color: #4B5563; 
    font-weight: 500;
}
.kpi-icon { 
    width: 20px; 
    height: 20px; 
    opacity: 0.6; 
}
.kpi-val { 
    font-size: 26px; 
    font-weight: 700; 
    color: #111827; 
    line-height: 1; 
}</value>
  </data>
  <data name="htmlContentControl2.HtmlTemplate.Template" xml:space="preserve">
    <value>&lt;div class="kpi-row"&gt;
    &lt;div class="kpi-card"&gt;
        &lt;div class="kpi-top"&gt;
            &lt;span class="kpi-title"&gt;Total Driver&lt;/span&gt;
            &lt;img src="bus" class="kpi-icon" alt="Bus" /&gt;
        &lt;/div&gt;
        &lt;div class="kpi-val"&gt;${TotalDrivers}&lt;/div&gt;
    &lt;/div&gt;
    
    &lt;div class="kpi-card"&gt;
        &lt;div class="kpi-top"&gt;
            &lt;span class="kpi-title"&gt;Not Working&lt;/span&gt;
            &lt;img src="wrench" class="kpi-icon" alt="Wrench" /&gt;
        &lt;/div&gt;
        &lt;div class="kpi-val"&gt;${NotWorking}&lt;/div&gt;
    &lt;/div&gt;
    
    &lt;div class="kpi-card no-margin"&gt;
        &lt;div class="kpi-top"&gt;
            &lt;span class="kpi-title"&gt;On The Road&lt;/span&gt;
            &lt;img src="id" class="kpi-icon" alt="Driver" /&gt;
        &lt;/div&gt;
        &lt;div class="kpi-val"&gt;${OnTheRoad}&lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;</value>
  </data>
