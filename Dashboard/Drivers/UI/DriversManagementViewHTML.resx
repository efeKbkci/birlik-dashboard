    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    flex-grow: 1;
    align-items: center;
    padding: 8px 24px;
    background-color: rgba(224, 227, 229, 0.3);
    border: 2px solid #E2E8F0;
    border-radius: 4px;
}

