  <data name="accordionControl1.HtmlTemplates.Group.Styles" xml:space="preserve">
    <value>.header-box {
    padding-left: 12px;
    padding-top: 24px;  /* Üstten istediğin 24px boşluk */
    padding-bottom: 24px; /* İlk sekmeyle arasına nefes alma boşluğu */
    display: flex;
    flex-direction: column;

}

.title {
    color: white;
    font-size: 28px;
    font-weight: bold;
}

.subtitle {
    color: #7696CB;
    font-size: 18px;
    margin-top: 4px;
}</value>
  </data>
  <data name="accordionControl1.HtmlTemplates.Item.Styles" xml:space="preserve">
    <value>.menu-item {
    display: flex;
    align-items: center;
    padding-left: 24px;
    height: 44px;
    cursor: pointer;
    
}

.icon {
    width: 24px;
    height: 24px;
    min-width: 24px; /* Flexbox'ın ikonu sıkıştırıp yok etmesini KESİN engeller */
    margin-right: 12px;
    object-fit: contain; /* İkonun en-boy oranını kusursuz korur */
}

.text {
    color: white;
    opacity: 0.7;
    font-size: 13px;
    white-space: nowrap; /* Yazının sığmayıp alt satıra düşmesini engeller */
}

.menu-item:hover {
    background-color: #009EE1;
}

.menu-item:hover .text {
    opacity: 1;
}</value>
  </data>
