  <data name="htmlContentControl2.HtmlTemplate.Styles" xml:space="preserve">
    <value>/* Ana Kart Kasası */
.form-card {
    background-color: #FFFFFF;
    border: 2px solid #C3C6D0;
    border-radius: 8px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    font-family: 'Segoe UI', sans-serif;
}

/* Başlık Alanı Hizalaması */
.card-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    margin-bottom: 20px;
}
.header-icon {
    width: 20px;
    height: 20px;
    margin-right: 8px; /* İkon ile yazı arası boşluk */
}
.header-title {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
}

/* Ana Form Taşıyıcısı */
.form-container {
    padding: 16px 0 16px 0;
    font-family: 'Segoe UI', Tahoma, sans-serif;
    background-color: transparent;
}

/* Genel Satır Yapısı */
.form-row {
    margin-bottom: 16px; /* Satırlar arası dikey mesafe */
}

/* Yan yana durması gereken Satır 1 için Flex düzeni */
.split-row {
    display: flex;
    flex-direction: row;
    width: 100%;
}

/* Elemanları saran genel kutu */
.field-wrapper {
    display: flex;
    flex-direction: column;
}

/* Yan yana duran elemanların her birinin %50 kaplaması için */
.half-width {
    flex-grow: 1;
    width: 50%;
}

/* Satır 1'deki iki kutunun arasına modern bir boşluk bırakır */
.margin-right {
    margin-right: 12px;
}

/* Üstteki küçük gri modern etiketler */
.field-label {
    font-size: 11px;
    font-weight: 600;
    color: #6b7280; /* Orta koyulukta gri */
    margin-bottom: 6px; /* Etiket ile kutu arasındaki nefes payı */
}

/* TAŞMAYI ÖNLEYEN SİHİRLİ KUTU (Box-Sizing Alternatifi) */
.input-container {
    position: relative; /* İçindeki input'un buna göre gerilmesi için ŞART */
    height: 38px; /* Kutunun sabit yüksekliği */
    align-items: center;
    justify-content: center;
    background-color: #ffffff;
    border: 1px solid #d1d5db; /* İnce modern çerçeve */
    border-radius: 6px; /* Hafif yuvarlak köşeler */
    transition: border-color 0.2s, box-shadow 0.2s;
}

/* Kutunun üzerine gelindiğinde veya odaklanıldığında parlaması */
.input-container:hover {
    border-color: #3b82f6; /* Modern mavi renk */
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
}

/* İÇERİYE GÖMÜLEN DEVERPRESS TEXTEDIT KONTROLLERİ */
.modern-input {
    position: absolute;
    top: 6px;
    left: 10px;  /* Sol iç boşluk (Padding hissi) */
    right: 10px; /* Sağ iç boşluk (Padding hissi) */
    
    flex-grow: 1; /* Kutuda kalan tüm boşluğu kaplamasını sağlar */
    width: 100%;
    border: none; /* HTML tarafında da kenarlığı kapatıyoruz */
    background-color: transparent; /* Şeffaf yapıyoruz ki dış kutunun rengi görünsün */
    font-family: 'Segoe UI', Tahoma, sans-serif;
    font-size: 14px;
    color: #111827; /* Koyu antrasit yazı rengi */
}

/* Butonun Olduğu Alt Alan */
.card-footer {
    display: flex;
    flex-direction: row;
    justify-content: flex-end; /* İçindeki butonu en sağa yaslar */
    margin-top: auto; /* Muazzam Özellik: Form ne kadar kısa olursa olsun, butonu kartın en altına kilitler! */
}

/* Beyaz, Gri Çerçeveli Modern Buton */
.btn-save {
    background-color: #FFFFFF;
    color: #374151;
    border: 1px solid #D1D5DB;
    padding: 10px 20px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.15s;
}
.btn-save:hover {
    background-color: #F9FAFB;
    border-color: #9CA3AF;
}</value>
