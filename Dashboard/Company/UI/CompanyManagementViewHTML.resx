  <data name="htmlContentControl1.HtmlTemplate.Styles" xml:space="preserve">
    <value>/* --- 1. ANA KASA --- */
.profile-card {
    background-color: #FFFFFF;
    border: 2px solid #C3C6D0;;
    border-radius: 8px;
    overflow: hidden; /* SİHİR 1: Banner resminin üst köşelerden dışarı taşmasını keser, yuvarlatır */
    display: flex;
    flex-direction: column; /* Artık yan yana değil, alt alta diziyoruz */
    font-family: 'Segoe UI', sans-serif;
    height: 215px;
}

/* --- 2. BANNER RESMİ --- */
.banner-img {
    width: 100%;
    height: 120px; /* Banner'ın yüksekliğini buradan ayarlayabilirsin */
    object-fit: cover; /* Resmin sündürülmeden alanı doldurmasını sağlar */
    display: block;
}

/* --- 3. ALT BEYAZ İÇERİK ALANI --- */
.content-area {
    display: flex;
    flex-direction: row;
    align-items: center; 
    padding: 0 24px 20px 24px; /* Üstüne padding vermedik çünkü logoyu oraya çekeceğiz */
}

/* --- 4. TAŞAN LOGO OPERASYONU --- */
.logo-wrapper {
    margin-top: -40px; /* SİHİR 2: Logoyu yukarıya, banner'ın içine doğru çeker */
    margin-right: 24px;
}
.logo-box {
    background-color: #0F172A;
    width: 80px;  /* Logoyu biraz daha heybetli yaptık */
    height: 80px;
    border-radius: 4px;
    border: 4px solid #FFFFFF; /* SİHİR 3: Tasarımdaki o kesilmiş beyaz çerçeve hissi */
    display: flex;
    justify-content: center;
    align-items: center;
}
.logo-box img { width: 40px; height: 40px; }

/* --- 5. BİLGİLER VE YAZILAR --- */
.info-box {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    margin-top: 12px; /* Logoyla dengeli durması için yazıları çok hafif aşağı iter */
}
.company-name {
    font-size: 24px;
    font-weight: bold;
    color: #111827;
    white-space: nowrap;
}
.subtitle-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    margin-top: 6px;
    white-space: nowrap;
}
.location-icon { width: 16px; height: 16px; }
.location {
    color: #4B5563;
    font-size: 14px;
    margin-left: 5px;
}
.badge-active {
    background-color: #E5E7EB;
    color: #111827;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 4px;
    margin-left: 10px;
}

/* --- 6. BUTON VE HİZALAMA --- */
.action-box {
    margin-left: auto;
    margin-top: 12px; /* Yazılarla aynı çizgide olması için */
}
.btn-edit {
    display: flex; 
    flex-direction: row;
    align-items: center;
    justify-content: center;
    background-color: #0F172A;
    color: white;
    padding: 10px 16px;
    border-radius: 4px;
    font-size: 14px;
    cursor: pointer;
    white-space: nowrap;
}
.btn-edit:hover { background-color: #0F172A; }
.btn-icon { width: 16px; height: 16px; margin-right: 8px; }</value>
