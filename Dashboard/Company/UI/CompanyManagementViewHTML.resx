  <data name="OverviewItemTemplate.Styles" xml:space="preserve">
    <value>/* Her Bir Liste Elemanı (İçteki Çerçeveli Kutular) */
.list-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 12px; /* Elemanlar arası dikey boşluk */
    background-color: #FAFAFA; /* Çok hafif gri arka plan */
    cursor: pointer;
    transition: border-color 0.2s;
}
.list-item:hover {
    border-color: #9CA3AF; /* Üzerine gelince çerçeve belirginleşir */
}

/* Soldaki Renkli İkon Kutuları */
.icon-box {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-right: 16px; /* Yazıyı sağa iter */
}
/* Arka plan renkleri (Tasarımda farklı renkler var) */
.bg-blue { background-color: #E0F2FE; }
.bg-gray { background-color: #F3F4F6; }
.bg-light-blue { background-color: #EFF6FF; }

.item-icon {
    width: 24px;
    height: 24px;
}

/* Orta Metin Alanı (Yay Gibi Esneyen Kısım) */
.text-box {
    display: flex;
    flex-direction: column;
    flex-grow: 1; /* SİHİRLİ DOKUNUŞ: Kalan tüm boşluğu kaplar ve oku en sağa fırlatır! */
}
.item-label {
    font-size: 12px;
    font-weight: 500;
    color: #6B7280;
    margin-bottom: 4px;
}
.item-value {
    font-size: 20px;
    font-weight: 600;
    color: #111827;
}</value>
  </data>
  <data name="OverviewItemTemplate.Template" xml:space="preserve">
    <value>&lt;div class="list-item"&gt;
    &lt;div class="icon-box ${ColorClass}"&gt;
        &lt;img src="${IconName}" class="item-icon" /&gt;
    &lt;/div&gt;
    &lt;div class="text-box"&gt;
        &lt;div class="item-label"&gt;${Title}&lt;/div&gt;
        &lt;div class="item-value"&gt;${Value}&lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;</value>
  </data>
  <data name="htmlContentControl4.HtmlTemplate.Styles" xml:space="preserve">
    <value>/* Ana Kart Kasası */
.overview-card {
    background-color: #FFFFFF;
    border: 2px solid #C3C6D0;;
    border-radius: 8px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    font-family: 'Segoe UI', sans-serif;
}

/* Başlık */
.card-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    margin-bottom: 24px; /* Altındaki liste ile arasındaki boşluk */
}
.header-icon {
    width: 20px;
    height: 20px;
    margin-right: 8px;
}
.header-title {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
}

/* Alt Alta Dizilen Liste Taşıyıcısı */
.list-container {
    display: flex;
    flex-direction: column;
    height: auto;
}

/*OverviewItemTemplate*/

/* Her Bir Liste Elemanı (İçteki Çerçeveli Kutular) */
.list-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    border: 2px solid #C3C6D0;
    border-radius: 6px;
    padding: 16px;
    margin-bottom: 12px; /* Elemanlar arası dikey boşluk */
    background-color: #F7F9FB; /* Çok hafif gri arka plan */
    cursor: pointer;
    transition: border-color 0.2s;
}
.list-item:hover {
    border-color: #9CA3AF; /* Üzerine gelince çerçeve belirginleşir */
}

/* Soldaki Renkli İkon Kutuları */
.icon-box {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-right: 16px; /* Yazıyı sağa iter */
    padding: 8px;
}
/* Arka plan renkleri (Tasarımda farklı renkler var) */
.bg-blue { background-color: #E0F2FE; }
.bg-gray { background-color: #F3F4F6; }
.bg-light-blue { background-color: #EFF6FF; }

.item-icon {
    width: 100%;
    height: 100%;
}

/* Orta Metin Alanı (Yay Gibi Esneyen Kısım) */
.text-box {
    display: flex;
    flex-direction: column;
    flex-grow: 1; /* SİHİRLİ DOKUNUŞ: Kalan tüm boşluğu kaplar ve oku en sağa fırlatır! */
}
.item-label {
    font-size: 12px;
    font-weight: 500;
    color: #6B7280;
    margin-bottom: 4px;
}
.item-value {
    font-size: 20px;
    font-weight: 600;
    color: #111827;
}</value>
  </data>
  <data name="htmlContentControl4.HtmlTemplate.Template" xml:space="preserve">
    <value>&lt;div class="overview-card"&gt;
    &lt;div class="card-header"&gt;
        &lt;img src="chart" class="header-icon" alt="Chart" /&gt;
        &lt;div class="header-title"&gt;Operational Overview&lt;/div&gt;
    &lt;/div&gt;
	
	&lt;div class="list-container"&gt;
		&lt;div class="list-item"&gt;
		    &lt;div class="icon-box ${ColorClass}"&gt;
		        &lt;img src="truck" class="item-icon" /&gt;
		    &lt;/div&gt;
		    &lt;div class="text-box"&gt;
		        &lt;div class="item-label"&gt;Active Vehicles&lt;/div&gt;
		        &lt;div class="item-value"&gt;${Vehicles}&lt;/div&gt;
	    	&lt;/div&gt;
		&lt;/div&gt;
		
			&lt;div class="list-item"&gt;
			    &lt;div class="icon-box ${ColorClass}"&gt;
			        &lt;img src="id" class="item-icon" /&gt;
			    &lt;/div&gt;
			    &lt;div class="text-box"&gt;
			        &lt;div class="item-label"&gt;Total Drivers&lt;/div&gt;
			        &lt;div class="item-value"&gt;${Drivers}&lt;/div&gt;
		    	&lt;/div&gt;
			&lt;/div&gt;
		
				&lt;div class="list-item"&gt;
		    &lt;div class="icon-box ${ColorClass}"&gt;
		        &lt;img src="route" class="item-icon" /&gt;
		    &lt;/div&gt;
		    &lt;div class="text-box"&gt;
		        &lt;div class="item-label"&gt;Total Reservation&lt;/div&gt;
		        &lt;div class="item-value"&gt;${Reservations}&lt;/div&gt;
	    	&lt;/div&gt;
		&lt;/div&gt;
	&lt;/div&gt;
&lt;/div&gt;

&lt;!--OverviewItemTemplate--&gt;</value>
  </data>
