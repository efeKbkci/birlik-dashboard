  <data name="htmlContentControl3.HtmlTemplate.Styles" xml:space="preserve">
    <value>.container{
	display: flex;
	height: 100%;
	align-content: center;
}

.header{
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    flex-grow: 1;
    align-items: center;
    padding: 16px 24px;
    background-color: rgba(224, 227, 229, 0.3);
    border: 2px solid #E2E8F0;
    border-radius: 4px;
}

.title {
    font-size: 18px;
    font-weight: 600;
    color: #0F172A;
}
.actions {
    display: flex;
    flex-direction: row;
}
.action-btn {
    width: 32px;
    height: 32px;
    border: 1px solid #CBD5E1;
    border-radius: 4px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-right: 8px;
    cursor: pointer;
}
